@using Microsoft.AspNetCore.Components.Authorization

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
    @* Dein AuthRedirect kann bleiben, aber AuthorizeRouteView ist sicherer *@
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            @* WICHTIG: Von RouteView auf AuthorizeRouteView wechseln! *@
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                
                <NotAuthorized>
                    @* Das hier sieht der Nutzer, wenn er NICHT eingeloggt ist 
                       und versucht, auf /dashboard zuzugreifen *@
                    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
                        <MudPaper Elevation="4" Class="pa-8">
                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
                                Zugriff verweigert
                            </MudAlert>
                            <MudText>Bitte loggen Sie sich ein, um diese Seite zu sehen.</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                                       Href="/" Class="mt-4">Zum Login</MudButton>
                        </MudPaper>
                    </MudContainer>
                </NotAuthorized>

                <Authorizing>
                    @* Wird angezeigt, während Blazor noch die API fragt: "Wer bist du?" *@
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </Authorizing>

            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudText Typo="Typo.h6">Sorry, diese Seite existiert nicht.</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>