@page "/settings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inherits LayoutComponentBase
@inject MiniWarehouse.Client.Service.ThemeService ThemeService

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4">Einstellungen</MudText>
        <MudText Typo="Typo.body1" Class="mt-4">Hier könnten ihre Einstellungen sein.</MudText>
        <MudDivider Class="my-4" />
        <MudCard>
            <MudText>Theme Style:</MudText>
            <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                           Color="Color.Inherit" 
                           OnClick="@ThemeService.ToggleDarkMode" />    
        </MudCard>
    </MudPaper>
</MudContainer>
